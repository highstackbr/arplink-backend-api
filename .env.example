PORT=3000
# Origens permitidas no CORS (separadas por vírgula). Ex.: http://localhost:3001 ou https://arplink-web-next-2q7z.vercel.app
CORS_ORIGINS=

# Conexão direta: postgresql://postgres:SENHA@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# Na Render, se der ENOTFOUND, use a URL do Connection Pooling (Supabase → Settings → Database → Connection pooling, porta 6543)
DATABASE_URL=
PG_SSL_REJECT_UNAUTHORIZED=false

SUPABASE_PROJECT_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=media
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_KEY_ID=
CLOUDFLARE_STREAM_PRIVATE_KEY=
CLOUDFLARE_CUSTOMER_SUBDOMAIN=

# E-mail ARPLINK (Brevo) – cadastro e recuperação de senha
# Na Render: use só BREVO_API_KEY (API usa HTTPS, evita ETIMEDOUT). Chave em Brevo → SMTP & API → Chaves API e MCP
BREVO_API_KEY=
ARPLINK_EMAIL_FROM=a4af3b001@smtp-brevo.com
FRONTEND_URL=http://localhost:3001
# Opcional (SMTP): se não usar BREVO_API_KEY, preencha SMTP_* (pode dar timeout em clouds)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=a4af3b001@smtp-brevo.com
# SMTP_PASS=
